---
import ImageViewer from '~/components/widgets/ImageViewer.astro'
import RSSViewClient from '~/components/widgets/RSSView.svelte'

interface Props {
  feedUrl: string
  viewMoreUrl?: string
  viewMoreText?: string
  class?: string
}

const {
  feedUrl,
  viewMoreUrl = feedUrl,
  viewMoreText = 'View more',
  class: className,
} = Astro.props as Props

if (!feedUrl) throw new Error('RSSView requires `feedUrl`.')
---

<div class:list={['rss-view-host', className]}>
  <RSSViewClient client:load {feedUrl} {viewMoreUrl} {viewMoreText} />
</div>

<ImageViewer
  selector=".rss-view-host .rss-view-list"
  options={{ title: 0, navbar: 0 }}
  asyncInsert={true}
/>
